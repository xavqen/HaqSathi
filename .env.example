# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="change-this-long-random-secret-at-least-32-chars"
NODE_ENV="development"

# Database - Supabase PostgreSQL
# Recommended local/dev:
# 1) Supabase Dashboard -> Connect -> ORMs -> Prisma
# 2) Paste the Transaction pooler URL into DATABASE_URL
# 3) Paste the Direct connection URL into DIRECT_URL
# 4) Replace [YOUR-PASSWORD] with your real DB password
# 5) If password has @ # / ? : symbols, URL-encode it
# Example pooler username is often postgres.PROJECT_REF, not only postgres.
DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.PROJECT_REF.supabase.co:5432/postgres"


# Google OAuth login
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth Client ID
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_AUTH_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# AI provider: optional. If empty, app uses safe local fallback drafts.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# Email-ready placeholder
RESEND_API_KEY=""
SUPPORT_EMAIL="support@haqsathi.local"
RESEND_FROM_EMAIL="HaqSathi AI <noreply@haqsathi.local>"

# Razorpay-ready placeholder
RAZORPAY_KEY_ID=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Seed
SEED_ADMIN_PASSWORD="Admin@123456"

# Supabase Storage for Document Vault
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="documents"
APP_ENV="local"
ADMIN_BACKUP_SECRET="change-this-admin-backup-secret"
NEXT_PUBLIC_SUPPORT_WHATSAPP=""

# Notification placeholders
NOTIFICATION_DRY_RUN="true"
WHATSAPP_PROVIDER_API_KEY=""
SMS_PROVIDER_API_KEY=""

# Launch/PWA
NEXT_PUBLIC_ENABLE_PWA="true"
NEXT_PUBLIC_APP_VERSION="2.1.0"
CLIENT_ERROR_LOG_DRY_RUN="true"

# Local/dev password reset: when true and RESEND_API_KEY is empty, API returns reset URL in response.
PASSWORD_RESET_DEV_LINKS="true"

# Phase 11 cron/reminder automation
CRON_SECRET=""


# Analytics (optional; leave blank for no tracking)
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# Smoke testing
SMOKE_BASE_URL="http://localhost:3000"

# Final launch controls
FINAL_LAUNCH_LOCK="false"
NEXT_PUBLIC_FINAL_RELEASE_CHANNEL="stable"
