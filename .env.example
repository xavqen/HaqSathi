# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="fill this with 34 character secret"
NODE_ENV="development"

# Database - Supabase PostgreSQL
# Recommended local/dev:
# 1) Supabase Dashboard -> Connect -> ORMs -> Prisma
# 2) Paste the Transaction pooler URL into DATABASE_URL
# 3) Paste the Direct connection URL into DIRECT_URL
# 4) Replace [YOUR-PASSWORD] with your real DB password
# 5) If password has @ # / ? : symbols, URL-encode it
# Example pooler username is often postgres.PROJECT_REF, not only postgres.
DATABASE_URL="postgresql://postgres.cctywlfzahavjfimxzrf:{password}@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.cctywlfzahavjfimxzrf:{password}@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"


