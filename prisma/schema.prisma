generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
  FAMILY
  AGENT
}

enum ComplaintStatus {
  DRAFT
  SENT
  FOLLOW_UP
  RESOLVED
  CLOSED
}

enum ReminderStatus {
  PENDING
  DONE
  CANCELLED
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
  CANCELLED
}

enum EscalationStatus {
  PLANNED
  READY
  SENT
  PAUSED
  RESOLVED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CaseTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum CaseTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LinkCheckStatus {
  UNKNOWN
  VERIFIED
  NEEDS_REVIEW
  BROKEN
}

enum SlaStatus {
  ON_TRACK
  AT_RISK
  MISSED
  DONE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String              @unique
  password           String?
  authProvider       String              @default("email")
  googleId           String?             @unique
  avatarUrl          String?
  emailVerifiedAt    DateTime?
  role               Role                @default(USER)
  plan               Plan                @default(FREE)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sessions           AuthSession[]
  complaints         Complaint[]
  schemeSearches     SchemeSearch[]
  documentChecklists DocumentChecklist[]
  reminders          Reminder[]
  subscriptions      Subscription[]
  chatSessions       ChatSession[]
  paymentOrders      PaymentOrder[]
  familyProfiles     FamilyProfile[]
  agentClients       AgentClient[]
  documentVaultItems DocumentVaultItem[]
  aiUsageEvents     AiUsageEvent[]
  supportTickets    SupportTicket[]
  blogPostsAuthored BlogPost[]          @relation("BlogPostAuthor")
  emailLogs         EmailLog[]
  activityEvents    UserActivity[]
  onboarding        OnboardingProgress?
  dataExports       DataExport[]
  notificationPreference NotificationPreference?
  templateUses      TemplateUse[]
  feedbackItems     Feedback[]
  caseTimelineEvents CaseTimelineEvent[]
  escalationPlans   EscalationPlan[]
  languagePreference UserLanguagePreference?
  savedOfficialLinks SavedOfficialLink[]
  riskAssessments   RiskAssessment[]
  legalToolResults   LegalToolResult[]
  evidencePacks      EvidencePack[]
  passwordResetTokens PasswordResetToken[]
  referralInvites ReferralInvite[]
  privacyConsents PrivacyConsent[]
  deletionRequests DataDeletionRequest[]
  reminderNotifications ReminderNotification[]
  caseNotes CaseNote[]
  caseTasks CaseTask[]
  aiOutputReviews AiOutputReview[]
  communicationLogs CommunicationLog[]
  caseOutcomes CaseOutcome[]
  authorityBookmarks AuthorityBookmark[]
  caseSlaTracks CaseSlaTrack[]
  agentInvoices AgentInvoice[]
  promptTestRuns PromptTestRun[]

  @@index([email])
  @@index([role])
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Complaint {
  id             String           @id @default(cuid())
  userId         String?
  user           User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  type           String
  companyName    String
  transactionId  String?
  amount         Decimal?         @db.Decimal(12, 2)
  issueDate      DateTime?
  description    String
  generatedDraft Json
  status         ComplaintStatus  @default(DRAFT)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  reminders      Reminder[]
  caseTimelineEvents CaseTimelineEvent[]
  escalationPlans EscalationPlan[]
  evidencePacks EvidencePack[]
  caseNotes CaseNote[]
  caseTasks CaseTask[]
  communicationLogs CommunicationLog[]
  caseOutcomes CaseOutcome[]
  caseSlaTracks CaseSlaTrack[]

  @@index([userId])
  @@index([type])
  @@index([companyName])
  @@index([createdAt])
}

model SchemeSearch {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  state       String
  age         Int
  category    String?
  incomeRange String
  purpose     String
  result      Json
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([state])
  @@index([purpose])
}

model DocumentChecklist {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      String
  inputData Json
  checklist Json
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
}

model Reminder {
  id                 String          @id @default(cuid())
  userId             String?
  user               User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  title              String
  dueDate            DateTime
  status             ReminderStatus  @default(PENDING)
  relatedComplaintId String?
  relatedComplaint   Complaint?      @relation(fields: [relatedComplaintId], references: [id], onDelete: SetNull)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([userId])
  @@index([dueDate])
  @@index([status])
}

model SeoPage {
  id              String   @id @default(cuid())
  slug            String
  type            String
  title           String
  metaDescription String
  content         Json
  faqJson         Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([type, slug])
  @@index([type])
  @@index([slug])
}

model Scheme {
  id              String   @id @default(cuid())
  title           String
  slug            String
  state           String
  purpose         String
  eligibility     String
  documents       Json
  applySteps      Json
  officialLink    String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([state, slug])
  @@index([state])
  @@index([purpose])
  @@index([isActive])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  title     String        @default("New help chat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([userId])
  @@index([updatedAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([sessionId])
  @@index([createdAt])
}


model FamilyProfile {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  relation     String
  age          Int?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model AgentClient {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  phone       String?
  caseType    String
  caseStatus  String   @default("OPEN")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  invoices    AgentInvoice[]

  @@index([userId])
  @@index([caseStatus])
}

model DocumentVaultItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  docType     String
  storagePath String?
  expiryDate  DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([docType])
  @@index([expiryDate])
}


model AiUsageEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  tool      String
  monthKey  String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tool])
  @@index([monthKey])
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  subject   String
  category  String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([category])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      Plan
  status    String
  provider  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model PaymentOrder {
  id              String        @id @default(cuid())
  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  plan            Plan
  amount          Int
  currency        String        @default("INR")
  provider        String        @default("razorpay")
  providerOrderId String?
  providerPaymentId String?
  providerSignature String?
  status          PaymentStatus @default(CREATED)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}


model BlogPost {
  id              String    @id @default(cuid())
  authorId        String?
  author          User?     @relation("BlogPostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  slug            String    @unique
  title           String
  excerpt         String
  metaTitle       String
  metaDescription String
  category        String
  tags            Json
  content         Json
  faqs            Json?
  status          String    @default("PUBLISHED")
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([category])
  @@index([publishedAt])
}

model EmailLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  toEmail   String
  subject   String
  template  String
  status    String   @default("QUEUED")
  provider  String   @default("resend")
  error     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([template])
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

model OnboardingProgress {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  completedSteps Json
  preferredState String?
  mainGoal       String?
  language       String   @default("HINGLISH")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DataExport {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  status    String   @default("READY")
  fileName  String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}


model NotificationPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailReminders      Boolean  @default(true)
  weeklyDigest        Boolean  @default(true)
  productUpdates      Boolean  @default(false)
  whatsappPlaceholder Boolean  @default(false)
  smsPlaceholder      Boolean  @default(false)
  language            String   @default("HINGLISH")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Template {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  category    String
  intent      String
  language    String        @default("HINGLISH")
  body        String
  variables   Json
  isPremium   Boolean       @default(false)
  usageCount  Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  uses        TemplateUse[]

  @@index([category])
  @@index([isPremium])
}

model TemplateUse {
  id         String    @id @default(cuid())
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  templateId String?
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  inputs     Json
  output     String
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([templateId])
  @@index([createdAt])
}

model OfficialResource {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  type        String
  state       String?
  description String
  url         String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([state])
  @@index([isVerified])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  entity    String
  entityId  String?
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([rating])
}


model CaseTimelineEvent {
  id          String     @id @default(cuid())
  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  complaintId String?
  complaint   Complaint? @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  type        String     @default("NOTE")
  title       String
  message     String?
  dueDate     DateTime?
  status      String     @default("OPEN")
  metadata    Json?
  createdAt   DateTime   @default(now())

  @@index([userId])
  @@index([complaintId])
  @@index([type])
  @@index([dueDate])
}

model EscalationPlan {
  id            String           @id @default(cuid())
  userId        String?
  user          User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  complaintId   String?
  complaint     Complaint?       @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  currentStage  String
  nextAction    String
  dueDate       DateTime?
  status        EscalationStatus @default(PLANNED)
  generatedPlan Json
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId])
  @@index([complaintId])
  @@index([status])
  @@index([dueDate])
}

model UserLanguagePreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  primaryLanguage String   @default("HINGLISH")
  assistantTone   String   @default("SIMPLE")
  readingLevel    String   @default("EASY")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SavedOfficialLink {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  title     String
  url       String
  category  String
  state     String?
  notes     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([category])
  @@index([state])
}

model RiskAssessment {
  id        String    @id @default(cuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  tool      String
  input     Json
  result    Json
  riskLevel RiskLevel @default(MEDIUM)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([tool])
  @@index([riskLevel])
  @@index([createdAt])
}


model LegalToolResult {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  tool      String
  input     Json
  result    Json
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tool])
  @@index([createdAt])
}

model EvidencePack {
  id          String     @id @default(cuid())
  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  complaintId String?
  complaint   Complaint? @relation(fields: [complaintId], references: [id], onDelete: SetNull)
  caseTitle   String
  category    String
  coverNote   String
  evidenceIndex Json
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([complaintId])
  @@index([category])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}


model ReferralInvite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String   @unique
  email     String?
  status    String   @default("CREATED")
  reward    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PrivacyConsent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  granted   Boolean  @default(true)
  source    String   @default("privacy-center")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([granted])
}

model DataDeletionRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String?
  status    String   @default("REQUESTED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ReminderNotification {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  reminderId String?
  channel    String   @default("EMAIL")
  status     String   @default("QUEUED")
  payload    Json
  sentAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([reminderId])
  @@index([status])
  @@index([createdAt])
}


model CaseNote {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  complaintId String?
  complaint   Complaint? @relation(fields: [complaintId], references: [id], onDelete: SetNull)
  title       String
  body        String
  visibility  String     @default("PRIVATE")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([complaintId])
  @@index([createdAt])
}

model CaseTask {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  complaintId String?
  complaint   Complaint?       @relation(fields: [complaintId], references: [id], onDelete: SetNull)
  title       String
  priority    CaseTaskPriority @default(MEDIUM)
  status      CaseTaskStatus   @default(TODO)
  dueDate     DateTime?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
  @@index([complaintId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
}

model AiOutputReview {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  tool      String
  sourceId  String?
  rating    Int
  issueType String
  comment   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tool])
  @@index([rating])
  @@index([issueType])
  @@index([createdAt])
}

model OfficialFilingGuide {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  category    String
  authority   String
  summary     String
  steps       Json
  documents   Json
  fees        String?
  timeline    String?
  officialUrl String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([authority])
  @@index([isVerified])
}

model CommunicationLog {
  id               String     @id @default(cuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  complaintId      String?
  complaint        Complaint? @relation(fields: [complaintId], references: [id], onDelete: SetNull)
  channel          String
  recipientName    String
  recipientContact String?
  subject          String
  message          String
  direction        String     @default("OUTBOUND")
  status           String     @default("PLANNED")
  nextFollowUpAt   DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([userId])
  @@index([complaintId])
  @@index([channel])
  @@index([status])
  @@index([nextFollowUpAt])
}

model CaseOutcome {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  complaintId     String?
  complaint       Complaint? @relation(fields: [complaintId], references: [id], onDelete: SetNull)
  outcomeType     String
  amountRecovered Decimal?   @db.Decimal(12, 2)
  resolutionDate  DateTime?
  summary         String
  learning        String?
  publicStory     Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([userId])
  @@index([complaintId])
  @@index([outcomeType])
  @@index([resolutionDate])
}

model AuthorityDirectoryEntry {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  category        String
  state           String?
  escalationLevel String   @default("BASIC")
  description     String
  email           String?
  phone           String?
  website         String?
  address         String?
  verified        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  bookmarks       AuthorityBookmark[]

  @@index([category])
  @@index([state])
  @@index([verified])
}

model AuthorityBookmark {
  id          String                  @id @default(cuid())
  userId      String
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  authorityId String
  authority   AuthorityDirectoryEntry @relation(fields: [authorityId], references: [id], onDelete: Cascade)
  notes       String?
  createdAt   DateTime                @default(now())

  @@unique([userId, authorityId])
  @@index([userId])
  @@index([authorityId])
}

model SeoKeywordOpportunity {
  id          String   @id @default(cuid())
  keyword     String   @unique
  intent      String
  category    String
  pageType    String
  priority    Int      @default(50)
  status      String   @default("IDEA")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([pageType])
  @@index([status])
  @@index([priority])
}


model StateGuide {
  id             String   @id @default(cuid())
  slug           String   @unique
  stateName      String
  language       String   @default("Hindi/Hinglish")
  summary        String
  popularProblems Json
  documents      Json
  helplines      Json
  applyTips      Json
  officialLinks  Json
  isPublished    Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([stateName])
  @@index([isPublished])
}

model OfficialLinkCheck {
  id            String          @id @default(cuid())
  label         String
  url           String
  category      String
  state         String   @default("National")
  status        LinkCheckStatus @default(UNKNOWN)
  notes         String?
  lastCheckedAt DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([label, category, state])
  @@index([category])
  @@index([state])
  @@index([status])
}

model SuccessStory {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  state       String?
  category    String
  summary     String
  steps       Json
  outcome     String
  disclaimer  String   @default("Anonymous educational example. Result har case me different ho sakta hai.")
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([state])
  @@index([isPublished])
}

model CaseSlaTrack {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  complaintId String?
  complaint   Complaint? @relation(fields: [complaintId], references: [id], onDelete: SetNull)
  title       String
  stage       String
  targetDate  DateTime
  status      SlaStatus  @default(ON_TRACK)
  riskNote    String?
  nextAction  String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([complaintId])
  @@index([status])
  @@index([targetDate])
}

model AgentInvoice {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentClientId String?
  agentClient   AgentClient?  @relation(fields: [agentClientId], references: [id], onDelete: SetNull)
  clientName    String
  serviceName   String
  amount        Decimal       @db.Decimal(12, 2)
  status        InvoiceStatus @default(DRAFT)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
  @@index([agentClientId])
  @@index([status])
  @@index([createdAt])
}

model PromptTestRun {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  tool        String
  input       Json
  output      Json
  score       Int      @default(0)
  issueNotes  String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([tool])
  @@index([score])
  @@index([createdAt])
}


model OfficialSource {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  category          String
  state             String   @default("National")
  department        String?
  url               String
  trustLevel        String   @default("OFFICIAL")
  status            String   @default("PENDING")
  verificationNotes String?
  lastVerifiedAt    DateTime?
  nextReviewAt      DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([category])
  @@index([state])
  @@index([status])
  @@index([nextReviewAt])
}

model ProductionQaRun {
  id        String   @id @default(cuid())
  area      String
  device    String
  browser   String
  status    String   @default("NOT_TESTED")
  checklist Json
  issues    Json
  testedBy  String?
  createdAt DateTime @default(now())

  @@index([area])
  @@index([status])
  @@index([createdAt])
}

model FeatureFlag {
  id             String   @id @default(cuid())
  key            String   @unique
  name           String
  description    String
  status         String   @default("DISABLED")
  audience       Json
  rolloutPercent Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
}

model IncidentReport {
  id          String   @id @default(cuid())
  title       String
  severity    String   @default("LOW")
  status      String   @default("OPEN")
  impact      String?
  rootCause   String?
  actionItems Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

model LaunchMetricSnapshot {
  id              String   @id @default(cuid())
  activeUsers     Int      @default(0)
  complaintCount  Int      @default(0)
  conversionRate  Float?
  revenueEstimate Decimal? @db.Decimal(12, 2)
  snapshot        Json
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

model SupportMacro {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  category  String
  body      Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model CasePackage {
  id            String   @id @default(cuid())
  userId        String?
  complaintId   String?
  title         String
  sections      Json
  downloadToken String?  @unique
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([complaintId])
  @@index([createdAt])
}

model TranslationSnippet {
  id        String   @id @default(cuid())
  key       String
  locale    String
  content   Json
  status    String   @default("DRAFT")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
  @@index([locale])
  @@index([status])
}

model PartnerLead {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  city        String
  state       String
  role        String   @default("CYBER_CAFE")
  expectedUse String?
  status      String   @default("NEW")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([state])
  @@index([status])
  @@index([createdAt])
}

model VerificationRequest {
  id            String   @id @default(cuid())
  userId        String
  title         String
  category      String
  sourceType    String   @default("COMPLAINT")
  sourceId      String?
  userQuestion  String
  aiOutput      String?
  status        String   @default("PENDING")
  reviewerNote  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
}

model PrintJob {
  id        String   @id @default(cuid())
  userId    String
  title     String
  jobType   String
  payload   Json
  status    String   @default("READY")
  copies    Int      @default(1)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([jobType])
  @@index([status])
  @@index([createdAt])
}

model LearningPathItem {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  category    String
  level       String   @default("BASIC")
  durationMin Int      @default(5)
  content     Json
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isPublished])
}

model Experiment {
  id             String   @id @default(cuid())
  key            String   @unique
  name           String
  hypothesis     String
  status         String   @default("DRAFT")
  variants       Json
  targetMetric   String
  rolloutPercent Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
}

model ModerationQueueItem {
  id        String   @id @default(cuid())
  userId    String?
  area      String
  risk      String   @default("LOW")
  input     String
  output    String?
  reason    String?
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([area])
  @@index([risk])
  @@index([status])
  @@index([createdAt])
}

model PlaybookArticle {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  category    String
  summary     String
  steps       Json
  disclaimer  String?
  status      String   @default("PUBLISHED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([status])
}

model LocalizationRequest {
  id        String   @id @default(cuid())
  locale    String
  pageKey   String
  source    String
  proposed  String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locale])
  @@index([status])
}

model KnowledgeFeedback {
  id        String   @id @default(cuid())
  articleId String?
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([articleId])
  @@index([rating])
}
